{
  "type": "module",
  "name": "warhammerbot",
  "version": "1.0.0",
  "description": "A Discord.js bot for Warhammer",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "deploy-commands": "node dist/deploy-commands.js",
    "cleanrun": "rm -rf dist && npm run build && npm run deploy-commands && node dist/index.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
